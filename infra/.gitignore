# Terraform state - contains secrets in plaintext
*.tfstate
*.tfstate.*

# Downloaded providers and modules
.terraform/

# May contain sensitive values
*.tfvars
!*.tfvars.example

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc
