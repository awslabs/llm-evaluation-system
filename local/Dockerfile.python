FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends wget curl ca-certificates && rm -rf /var/lib/apt/lists/*

# Install Docker CLI + Compose plugin (not the daemon)
COPY --from=docker:27-cli /usr/local/bin/docker /usr/local/bin/docker
COPY --from=docker:27-cli /usr/local/libexec/docker/cli-plugins/docker-compose /usr/local/libexec/docker/cli-plugins/docker-compose

# Install crane (extract files from container images without Docker daemon)
COPY --from=gcr.io/go-containerregistry/crane:latest /ko-app/crane /usr/local/bin/crane

# Install Helm CLI (required by inspect-k8s-sandbox)
COPY --from=alpine/helm:3.17.3 /usr/bin/helm /usr/local/bin/helm

COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

WORKDIR /app
COPY pyproject.toml uv.lock ./
RUN uv sync --locked --extra dev --extra backend --extra k8s-sandbox --extra providers
ENV PATH="/app/.venv/bin:$PATH"

COPY backend/ ./backend/
COPY local/ ./local/

ENV PYTHONPATH=/app
